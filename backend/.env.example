APP_ENV=development
SECRET_KEY=replace-this-secret
ROLE_ELEVATION_CODE=replace-this-role-elevation-code
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=plantify-api
JWT_AUDIENCE=plantify-clients
SQLITE_PATH=/data/plantify.db
MODEL_PATH=/app/model/plantify_model.onnx
LABELS_PATH=/app/model/classes.json
CHATBOT_MODEL_NAME=qwen2.5:1.5b
CHATBOT_BASE_URL=http://ollama:11434
CHATBOT_AUTO_PULL_MODEL=true
CHATBOT_PULL_TIMEOUT_SECONDS=900
CORS_ORIGINS=https://plantify.limarise.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost,http://127.0.0.1
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_FOREIGN_KEYS=true
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
RATE_LIMIT_SIGNUP_PER_MINUTE=10
RATE_LIMIT_LOGIN_PER_MINUTE=20
RATE_LIMIT_DETECT_PER_MINUTE=60
SLO_TARGET_AVAILABILITY=0.99
SLO_TARGET_P95_SECONDS=0.75
SLO_MIN_REQUESTS_FOR_EVALUATION=50
