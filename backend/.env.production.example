# Production Backend Configuration
# Copy this file to .env and replace values with real production secrets

APP_ENV=production
SECRET_KEY=<REPLACE_WITH_32_CHAR_PRODUCTION_SECRET_FROM_GITHUB_SECRETS>
ROLE_ELEVATION_CODE=<REPLACE_WITH_ROLE_ELEVATION_CODE_FROM_GITHUB_SECRETS>
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=plantify-api
JWT_AUDIENCE=plantify-clients
SQLITE_PATH=/data/plantify.db
MODEL_PATH=/app/model/plantify_model.onnx
LABELS_PATH=/app/model/classes.json
CORS_ORIGINS=https://plantify.limarise.com,https://app.plantify.limarise.com
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin,X-Request-ID
SECURITY_CSP=default-src 'none'; frame-ancestors 'none'; base-uri 'none'
SECURITY_HSTS_MAX_AGE_SECONDS=31536000
SQLITE_JOURNAL_MODE=WAL
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_FOREIGN_KEYS=true
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
RATE_LIMIT_SIGNUP_PER_MINUTE=5
RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_DETECT_PER_MINUTE=30
SLO_TARGET_AVAILABILITY=0.99
SLO_TARGET_P95_SECONDS=0.75
SLO_MIN_REQUESTS_FOR_EVALUATION=100
