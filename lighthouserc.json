{
  "ci": {
    "collect": {
      "staticDistDir": "frontend/out",
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.8
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.6
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.8
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.8
          }
        ],
        "categories:pwa": [
          "off"
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
