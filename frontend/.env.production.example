# Production Frontend Configuration
# Copy this file to .env.production.local and replace values with real production URLs

NEXT_PUBLIC_API_BASE_URL=https://api.plantify.limarise.com/api
NEXT_PUBLIC_MOBILE_DEV_API_URL=http://192.168.1.50:8000/api
NEXT_PUBLIC_PRODUCTION_API_URL=https://api.plantify.limarise.com/api
NEXT_PUBLIC_BUILD_ENV=production
NEXT_PUBLIC_APP_STAGE=production

# Sentry error tracking for production
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Analytics
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Feature flags
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
